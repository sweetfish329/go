# Build stage
FROM golang:1.26-alpine AS builder

WORKDIR /app

# Install git for fetch dependencies if needed
RUN apk add --no-cache git

# Copy the application source code first so that go mod tidy can scan imports
COPY . .

# Run go mod tidy inside container to resolve dependency issues
RUN go mod tidy && go mod download

# Build the executable
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o server ./cmd/server

# Run stage
FROM alpine:latest

# Security: Install ca-certificates and run as non-root user
RUN apk --no-cache add ca-certificates && adduser -D appuser
USER appuser

WORKDIR /app
COPY --from=builder /app/server .

ENV PORT=8080
EXPOSE 8080

CMD ["./server"]
